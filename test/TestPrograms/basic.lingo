-- Identity
id : {A : U} -> A -> A
id a := a

#check id 32

-- Projections
dfst : {A : U} -> {B : A -> U} -> (a : A) x B a -> A
dfst (a, b) := a

#check dfst

dsnd : {A : U} -> {B : A -> U} -> (p : (a : A) x B a) -> B (dfst {A} {B} p)
dsnd (a, b) := b

#check dsnd

fst : {A : U} -> {B : U} -> A x B -> A
fst p := dfst {A} {\a. B} p

#check fst (*, 32)

snd : {A : U} -> {B : U} -> A x B -> B
snd p := dsnd {A} {\a. B} p

#check snd (*, 32)

-- Composition
comp : {A : U} -> {B : U} -> {C : U} -> (B -> C) -> (A -> B) -> A -> C
comp g f a := g (f a)

#check comp

-- Propositional Logic
not : (A : U) -> U
not A := A -> _|_

modusPonens : {P : U} -> {Q : U} -> P x (P -> Q) -> Q
modusPonens p := (snd p) (fst p)

#type modusPonens
