-- Projections
dfst : {A : U} -> {B : A -> U} -> (a : A) x B a -> A
dfst (a, b) := a

dsnd : {A : U} -> {B : A -> U} -> (p : (a : A) x B a) -> B (dfst {A} {B} p)
dsnd (a, b) := b

fst : {A : U} -> {B : U} -> A x B -> A
fst p := dfst {A} {\a. B} p

snd : {A : U} -> {B : U} -> A x B -> B
snd p := dsnd {A} {\a. B} p

lift : {A : U} -> {B : U} -> {a : A} -> {b : A} -> (f : A -> B) -> a = b -> f a = f b
lift f p := ind[=[A]](a. b. p. f a = f b, z. refl, a, b, p)


-- Identity on type constructors
productPath : {A : U} -> {B : U} -> (a : A x B) -> (b : A x B) -> (p : a = b) -> (fst a = fst b) x (snd a = snd b)

#check lift
productPath a b p := (lift fst p, lift snd p)


#check snd (*, 32)

-- Composition
comp : {A : U} -> {B : U} -> {C : U} -> (B -> C) -> (A -> B) -> A -> C
comp g f a := g (f a)

#check comp

flip : {A : U} -> {B : U} -> {C : U} -> (A -> B -> C) -> B -> A -> C
flip f b a := f a b

-- Propositional Logic
not : (A : U) -> U
not A := A -> _|_

modusPonens : {P : U} -> {Q : U} -> P x (P -> Q) -> Q
modusPonens p := (snd p) (fst p)

#type modusPonens
