not : (A : U) -> U
not A := A -> _|_

-- Identity
id : {A : U} -> A -> A
id a := a

#check id 32

-- Projections
dfst : {A : U} -> {B : A -> U} -> (a : A) x B a -> A
dfst (a, b) := a

#check dfst

dsnd : {A : U} -> {B : A -> U} -> (p : (a : A) x B a) -> B (dfst p)
dsnd (a, b) := b

#check dsnd

fst : {A : U} -> {B : U} -> A x B -> A
fst p := dfst p

#check fst (*, 32)

snd : {A : U} -> {B : U} -> A x B -> B
snd p := dsnd p

#check snd (*, 32)

-- Composition
comp : {A : U} -> {B : U} -> {C : U} -> (B -> C) -> (A -> B) -> A -> C
comp g f a := g (f a)

#check comp

flip : {A : U} -> {B : U} -> {C : U} -> (A -> B -> C) -> B -> A -> C
flip f b a := f a b

-- Propositional Logic


#check not

modusPonens : {P : U} -> {Q : U} -> P x (P -> Q) -> Q
modusPonens (p, h) := h p

#type modusPonens
