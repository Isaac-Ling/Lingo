-- Function extensionality
fun1 : T -> T
fun2 : T -> T

fun1PointwiseEqualsFun2 : (a : T) -> fun1 a = fun2 a
fun1PointwiseEqualsFun2 a := idTrans (uniqT (fun1 a)) (idSymm (uniqT (fun2 a)))

fun1EqualsFun2 : fun1 = fun2
fun1EqualsFun2 := funext(fun1PointwiseEqualsFun2)

#type fun1EqualsFun2

homotopic : {A : U} -> {B : U} -> (f : A -> B) -> (g : A -> B) -> U
homotopic f g := (a : A) -> f a = g a

#check homotopic fun1 fun2

-- Homotopy equivalence relation
homotopyRefl : {A : U} -> {B : U} -> (f : A -> B) -> homotopic f f
homotopyRefl f a := refl

#check homotopyRefl

homotopySymm : {A : U} -> {B : U} -> (f : A -> B) -> (g : A -> B) -> homotopic f g -> homotopic g f
homotopySymm f g hfg a := idSymm (hfg a)

#check homotopySymm

homotopyTrans : {A : U} -> {B : U} -> (f : A -> B) -> (g : A -> B) -> (h : A -> B) -> homotopic f g -> homotopic g h -> homotopic f h
homotopyTrans f g h hfg hgh a := idTrans (hfg a) (hgh a)

#check homotopyTrans

-- Quasi-inverse
qinv : {A : U} -> {B : U} -> (f : A -> B) -> U
qinv f := (g : B -> A) x (homotopic (comp f g) id) x (homotopic (comp g f) id)

#eval qinv

-- TODO: Use half adjoint equivalences to define isequiv
isequiv : (A : U) -> (B : U) -> U
isequiv A B := (f : A -> B) x (qinv f)

#eval isequiv

idSelfInverse : {A : U} -> qinv (id {A})
idSelfInverse := (id, \a. refl, \a. refl)

#check idSelfInverse

isequivRefl : (A : U) -> isequiv A A
isequivRefl A := (id, idSelfInverse)

#type isequivRefl

-- Formalised from Theorem 2.8.1 in HoTT book

allUnitEq : (a : T) -> (b : T) -> T -> a = b
allUnitEq * * u := refl

unitPathEquivLemma : {a : T} -> {b : T} -> (p : a = b) -> allUnitEq a b * = p
unitPathEquivLemma p := ind[=[T]](c. d. q. allUnitEq c d * = q, z. ind[T](z'. allUnitEq z' z' * = refl, refl, z), a, b, p)

unitPathEquiv : (a : T) -> (b : T) -> isequiv (a = b) T
unitPathEquiv a b := (\(p : a = b). *, allUnitEq a b, \(a : T). idSymm (uniqT a), \(p : a = b). unitPathEquivLemma p)

#type unitPathEquiv

happly : {A : U} -> {B : U} -> (f : A -> B) -> (g : A -> B) -> f = g -> (a : A) -> f a = g a
happly f g p a := ind[=[A -> B]](f. g. p'. f a = g a, z. refl, f, g, p)
