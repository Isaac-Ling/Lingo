-- Function extensionality
id1 : T -> T
id1 := \a. a

id2 : T -> T
id2 := \b. b

id1PointwiseEqualsId2 : (a : T) -> id1 a = id2 a
id1PointwiseEqualsId2 a := refl[a]

--id1EqualsId2 : id1 = id2
--id1EqualsId2 := funext(id1PointwiseEqualsId2)

--#check id1EqualsId2

homotopic : {A : U} -> {B : U} -> (f : A -> B) -> (g : A -> B) -> U
homotopic f g := (a : A) -> f a = g a

#check homotopic id1 id2

-- Homotopy equivalence relation
homotopyRefl : {A : U} -> {B : U} -> (f : A -> B) -> homotopic f f
homotopyRefl f a := refl[f a]

#check homotopyRefl

homotopySymm : {A : U} -> {B : U} -> (f : A -> B) -> (g : A -> B) -> homotopic f g -> homotopic g f
homotopySymm f g hfg a := idSymm (hfg a)

#check homotopySymm

homotopyTrans : {A : U} -> {B : U} -> (f : A -> B) -> (g : A -> B) -> (h : A -> B) -> homotopic f g -> homotopic g h -> homotopic f h
homotopyTrans f g h hfg hgh a := idTrans (hfg a) (hgh a)

#check homotopyTrans

-- Quasi-inverse
qinv : {A : U} -> {B : U} -> (f : A -> B) -> U
qinv f := (g : B -> A) x (homotopic (comp f g) id) x (homotopic (comp g f) id)

#eval qinv

-- TODO: Use half adjoint equivalences to define isequiv
isequiv : (A : U) -> (B : U) -> U
isequiv A B := (f : A -> B) x (qinv f)

#eval isequiv

idSelfInverse : {A : U} -> qinv (id {A})
idSelfInverse := (id, \a. refl[a], \a. refl[a])

#check idSelfInverse

-- Formalised from Theorem 2.8.1 in HoTT book

allUnitEq : (a : T) -> (b : T) -> T -> a = b
allUnitEq a b u := ind[T](a. a = b, ind[T](b. * = b, refl[*], b), a)

unitPathEquivLemma : {a : T} -> {b : T} -> (p : a = b) -> allUnitEq a b * = p
unitPathEquivLemma p := ind[=[T]](c. d. q. allUnitEq c d * = q, z. ind[T](z'. allUnitEq z' z' * = refl[z'], refl[refl[*]], z), a, b, p)

unitPathEquiv : (a : T) -> (b : T) -> isequiv (a = b) T
unitPathEquiv a b := (\(p : a = b). *, allUnitEq a b, \(a : T). idSymm (uniqT a), \(p : a = b). unitPathEquivLemma p)

#type unitPathEquiv

happly : {A : U} -> {B : U} -> (f : A -> B) -> (g : A -> B) -> f = g -> (a : A) -> f a = g a
happly f g p a := ind[=[A -> B]](f. g. p'. f a = g a, z. refl[z a], f, g, p)

funextEta : {A : U} -> {B : U} -> (f : A -> B) -> (g : A -> B) -> ((a : A) -> f a = g a) -> f = g
funextEta f g p := funext(p)

-- TODO: Define these lemmas
piPathEquivLemma1 : {A : U} -> {B : U} -> (f : A -> B) -> (g : A -> B) -> (h : (a : A) -> f a = g a) -> happly f g funext(h) = h
piPathEquivLemma2 : {A : U} -> {B : U} -> (f : A -> B) -> (g : A -> B) -> (p : f = g) -> funext(happly f g p) = p

piPathEquiv : {A : U} -> {B : U} -> (f : A -> B) -> (g : A -> B) -> isequiv (f = g) ((a : A) -> f a = g a)
piPathEquiv f g := (happly f g, funextEta f g, \h. piPathEquivLemma1 f g h, \p. piPathEquivLemma2 f g p)

#type piPathEquiv
