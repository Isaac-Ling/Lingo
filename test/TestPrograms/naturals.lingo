-- Natural Numbers
add : Nat -> Nat -> Nat
add 0       n := n
add succ(m) n := succ(add m n)

congSucc : {a : Nat} -> {b : Nat} -> a = b -> succ(a) = succ(b)
congSucc := lift (\n. succ(n))

rAddId : (a : Nat) -> add a 0 = a
rAddId 0       := refl
rAddId succ(n) := congSucc (rAddId n)

#check rAddId

addComm : (a : Nat) -> (b : Nat) -> add a b = add b a
addComm 0       0       := refl
addComm 0       succ(n) := idSymm (rAddId n)
addComm succ(m) 0       := rAddId succ(m)
-- TODO: Using a different var name to other case should still work:
--addComm succ(n) 0       := rAddId n
addComm succ(m) succ(n) := congSucc (addComm succ(m) n)

