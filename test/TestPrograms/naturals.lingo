-- Natural Numbers
a : Nat
a := 5

#check a

double : Nat -> Nat
double 0       := 0
double succ(n) := succ(succ(double n))

#check double a

add : Nat -> Nat -> Nat
add 0       n := n
add succ(m) n := succ(add m n)

#check add 2 2

twoPlusTwoIsFour : add 2 2 = 4
twoPlusTwoIsFour := refl

#check twoPlusTwoIsFour

multiply : Nat -> Nat -> Nat
multiply 0       n := 0
multiply succ(m) n := add n (multiply m n)

#check multiply 2 4

lMul0 : (a : Nat) -> multiply 0 a = 0
lMul0 a := refl

#check lMul0

pow : Nat -> Nat -> Nat
pow m 0       := 1
pow m succ(n) := multiply m (pow m n)

#check pow 2 5

lAddId : (a : Nat) -> add 0 a = a
lAddId a := refl

#check lAddId

congSucc : {a : Nat} -> {b : Nat} -> a = b -> succ(a) = succ(b)
congSucc := lift (\n. succ(n))

#check congSucc

rAddId : (a : Nat) -> add a 0 = a
rAddId 0       := refl
rAddId succ(n) := congSucc (rAddId n)

#check rAddId

moveSucc : (a : Nat) -> (b : Nat) -> add succ(a) b = add a succ(b)
moveSucc 0       n := refl
moveSucc succ(m) n := congSucc (moveSucc m n)

#type moveSucc

addComm : (a : Nat) -> (b : Nat) -> add a b = add b a
addComm 0       0       := refl
addComm 0       succ(n) := idSymm (rAddId succ(n))
addComm succ(n) 0       := rAddId succ(n)
addComm succ(m) succ(n) := idSymm (congSucc (idTrans (idSymm (addComm succ(m) n)) (moveSucc m n)))

#type addComm

addAssoc : (a : Nat) -> (b : Nat) -> (c : Nat) -> add (add a b) c = add a (add b c)
addAssoc 0       b c := refl
addAssoc succ(a) b c := congSucc (addAssoc a b c)

#type addAssoc

natMagma : Magma
natMagma := (Nat, add)

#check natMagma

natSemiGroup : SemiGroup
natSemiGroup := (natMagma, addAssoc)

#type natSemiGroup
