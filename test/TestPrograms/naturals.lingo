-- Natural Numbers
a : Nat
a := 5

#check a

double : Nat -> Nat
double 0       := 0
double succ(n) := succ(succ(double n))

#check double a

add : Nat -> Nat -> Nat
add 0       n := n
add succ(m) n := succ(add m n)

#check add
#check add 2 2

twoPlusTwoIsFour : add 2 2 = 4
twoPlusTwoIsFour := refl

#check twoPlusTwoIsFour

multiply : Nat -> Nat -> Nat
multiply 0       n := 0
multiply succ(m) n := add n (multiply m n)

#check multiply 2 4

lMul0 : (a : Nat) -> multiply 0 a = 0
lMul0 a := refl[0]

#check lMul0

powFlipped : Nat -> Nat -> Nat
powFlipped n := ind[Nat](Nat -> Nat, \n. 1, n'. g. \m. multiply m (g m), n)

flip : {A : U} -> {B : U} -> {C : U} -> (A -> B -> C) -> B -> A -> C
flip f b a := f a b

pow := flip powFlipped

#check pow 2 5

rAddId : (a : Nat) -> add a 0 = a
rAddId a := ind[Nat](n. add n 0 = n, refl, m. g. lift (\n. succ(n)) g, a)

#check rAddId

addCommLemma : (a : Nat) -> (b : Nat) -> add a succ(b) = add succ(a) b
addCommLemma a b := ind[Nat](n. add n succ(b) = add succ(n) b, refl, m. g. lift (\n. succ(n)) g, a)

addComm : (a : Nat) -> (b : Nat) -> add a b = add b a
addComm a b := ind[Nat](n. add a n = add n a, rAddId a, m. g. idTrans (addCommLemma a m) (lift (\n. succ(n)) g), b)

#type addComm
