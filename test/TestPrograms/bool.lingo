-- Boolean
Bool := T + T

#check Bool

true : Bool
true := inl(*)

false : Bool
false := inr(*)

#check true
#check false

-- Conditional
ifThenElse : {C : U} -> Bool -> C -> C -> C
itThenElse inl(*) c c' := c
itThenElse inr(*) c c' := c'
--ifThenElse b c c' := ind[Bool](C, a. c, a. c', b)

#check ifThenElse

boolNot : Bool -> Bool
boolNot b := ifThenElse b false true

#check boolNot false
