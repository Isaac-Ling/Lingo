-- Boolean
Bool := T + T

#check Bool

true : Bool
true := inl(*)

false : Bool
false := inr(*)

#check true
#check false

-- Conditional
ifThenElse : {C : U} -> Bool -> C -> C -> C
ifThenElse inl(a) c c' := c
ifThenElse inr(a) c c' := c'

#check ifThenElse

boolNot : Bool -> Bool
boolNot b := ifThenElse b false true

#check boolNot false

-- Pattern matching
-- TODO: This fails because injection doesn't specify type??
-- Use known type from type declaration
sumPattern : {A : U} -> A + A -> A + A -> A
sumPattern inl(a) t      := a
sumPattern inr(b) inl(c) := c
sumPattern inr(b) inr(d) := b

