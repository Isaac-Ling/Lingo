-- Boolean
Bool := T + T

#check Bool

true : Bool
true := inl(*)

false : Bool
false := inr(*)

#check true
#check false

-- Conditional
ifThenElse : {C : U} -> Bool -> C -> C -> C
ifThenElse inl(a) c c' := c
ifThenElse inr(a) c c' := c'

#check ifThenElse

boolNot : Bool -> Bool
boolNot b := ifThenElse b false true

#check boolNot false
