binaryOp : U -> U
binaryOp s := s -> s -> s

Magma : U1
Magma := (M : U) x (binaryOp M)

-- Compare with no pattern matching, needing many fst/snds etc
magmaIsAssoc : Magma -> U
magmaIsAssoc (M, op) := (a : M) -> (b : M) -> (c : M) -> op (op a b) c = op a (op b c)

SemiGroup : U1
SemiGroup := (M : Magma) x (magmaIsAssoc M)

magmaHasIdentity : Magma -> U
magmaHasIdentity (M, op) := (e : M) x ((a : M) -> op e a = a) x ((a : M) -> op a e = a)

semiGroupHasIdentity : SemiGroup -> U
semiGroupHasIdentity (M, a) := magmaHasIdentity M

Monoid : U1
Monoid := (G : Magma) x (magmaHasIdentity G)
